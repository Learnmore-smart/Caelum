<Window
    x:Class="Caelum.PageTemplatePickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Insert Page"
    Width="620"
    Height="560"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    Background="Transparent"
    AllowsTransparency="True"
    ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="TemplateCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FBFF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF6FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#14000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F8F8FB" CornerRadius="22" Padding="24" BorderBrush="#DADAE2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937"/>
                    <TextBlock x:Name="SubtitleTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="#6B7280" TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Width="34"
                        Height="34"
                        Margin="12,0,0,0"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#14000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#4B5563"/>
                </Button>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0,24,0,0">
                <Button x:Name="BlankCard" Click="BlankCard_Click" Style="{StaticResource TemplateCardButtonStyle}" Margin="0,0,10,10">
                    <StackPanel Margin="18">
                        <Border Height="160" CornerRadius="16" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid Margin="18">
                                <Rectangle RadiusX="10" RadiusY="10" Fill="#FFFFFF" Stroke="#E5E7EB" StrokeThickness="1"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="BlankTitleTextBlock" Margin="0,16,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="BlankHintTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>

                <Button x:Name="NotebookCard" Click="NotebookCard_Click" Style="{StaticResource TemplateCardButtonStyle}" Margin="10,0,0,10">
                    <StackPanel Margin="18">
                        <Border Height="160" CornerRadius="16" Background="#FDF9EE" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid Margin="18">
                                <Rectangle RadiusX="10" RadiusY="10" Fill="#FDF9EE" Stroke="#E5E7EB" StrokeThickness="1"/>
                                <Line X1="28" Y1="0" X2="28" Y2="124" Stroke="#EF4444" StrokeThickness="1.5"/>
                                <Line X1="0" Y1="22" X2="120" Y2="22" Stroke="#C8DDFC" StrokeThickness="1"/>
                                <Line X1="0" Y1="46" X2="120" Y2="46" Stroke="#C8DDFC" StrokeThickness="1"/>
                                <Line X1="0" Y1="70" X2="120" Y2="70" Stroke="#C8DDFC" StrokeThickness="1"/>
                                <Line X1="0" Y1="94" X2="120" Y2="94" Stroke="#C8DDFC" StrokeThickness="1"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="NotebookTitleTextBlock" Margin="0,16,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="NotebookHintTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>

                <Button x:Name="LinedCard" Click="LinedCard_Click" Style="{StaticResource TemplateCardButtonStyle}" Margin="0,10,10,0">
                    <StackPanel Margin="18">
                        <Border Height="160" CornerRadius="16" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid Margin="18">
                                <Rectangle RadiusX="10" RadiusY="10" Fill="#FFFFFF" Stroke="#E5E7EB" StrokeThickness="1"/>
                                <Line X1="0" Y1="20" X2="120" Y2="20" Stroke="#CBD5E1" StrokeThickness="1"/>
                                <Line X1="0" Y1="44" X2="120" Y2="44" Stroke="#CBD5E1" StrokeThickness="1"/>
                                <Line X1="0" Y1="68" X2="120" Y2="68" Stroke="#CBD5E1" StrokeThickness="1"/>
                                <Line X1="0" Y1="92" X2="120" Y2="92" Stroke="#CBD5E1" StrokeThickness="1"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="LinedTitleTextBlock" Margin="0,16,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="LinedHintTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>

                <Button x:Name="QuadrilleCard" Click="QuadrilleCard_Click" Style="{StaticResource TemplateCardButtonStyle}" Margin="10,10,0,0">
                    <StackPanel Margin="18">
                        <Border Height="160" CornerRadius="16" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid Margin="18">
                                <Rectangle RadiusX="10" RadiusY="10" Fill="#FFFFFF" Stroke="#E5E7EB" StrokeThickness="1"/>
                                <Line X1="24" Y1="0" X2="24" Y2="124" Stroke="#BFDBFE" StrokeThickness="1"/>
                                <Line X1="48" Y1="0" X2="48" Y2="124" Stroke="#DBEAFE" StrokeThickness="1"/>
                                <Line X1="72" Y1="0" X2="72" Y2="124" Stroke="#DBEAFE" StrokeThickness="1"/>
                                <Line X1="96" Y1="0" X2="96" Y2="124" Stroke="#BFDBFE" StrokeThickness="1"/>
                                <Line X1="0" Y1="24" X2="120" Y2="24" Stroke="#BFDBFE" StrokeThickness="1"/>
                                <Line X1="0" Y1="48" X2="120" Y2="48" Stroke="#DBEAFE" StrokeThickness="1"/>
                                <Line X1="0" Y1="72" X2="120" Y2="72" Stroke="#DBEAFE" StrokeThickness="1"/>
                                <Line X1="0" Y1="96" X2="120" Y2="96" Stroke="#BFDBFE" StrokeThickness="1"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="QuadrilleTitleTextBlock" Margin="0,16,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="QuadrilleHintTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <StackPanel Grid.Row="2" Margin="0,24,0,0">
                <Border x:Name="PathSectionBorder"
                        Visibility="Collapsed"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="PathLabelTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"/>

                        <TextBlock x:Name="SelectedFolderPathTextBlock"
                                   Grid.Column="1"
                                   Margin="12,0,12,0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#111827"
                                   TextTrimming="CharacterEllipsis"/>

                        <Button x:Name="BrowsePathButton"
                                Grid.Column="2"
                                Click="BrowsePathButton_Click"
                                Style="{StaticResource IconButtonStyle}">
                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#374151"/>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="CreateButton"
                            Visibility="Collapsed"
                            Click="CreateButton_Click"
                            Style="{StaticResource DialogPrimaryButton}"
                            Margin="0,0,10,0"/>
                    <Button x:Name="CancelButton" Click="CancelButton_Click" Style="{StaticResource DialogSecondaryButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
