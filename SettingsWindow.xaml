<Window
    x:Class="WindowsNotesApp.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="500"
    Height="390"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    Background="Transparent"
    AllowsTransparency="True"
    ShowInTaskbar="False">

    <Border Background="#F8F8FB" CornerRadius="22" Padding="24" BorderBrush="#DADAE2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock" FontSize="24" FontWeight="SemiBold" Foreground="#1F2937"/>
                    <TextBlock x:Name="SubtitleTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="#6B7280" TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Width="34"
                        Height="34"
                        Margin="12,0,0,0"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#14000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#4B5563"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,22,0,0">
                <Border Background="White" CornerRadius="18" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="LanguageLabelTextBlock" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="LanguageHintTextBlock" Grid.Row="1" Margin="0,8,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"/>
                        <ComboBox Grid.Row="2"
                                  x:Name="LanguageComboBox"
                                  Margin="0,14,0,0"
                                  Height="36"
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Language"/>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="18" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock x:Name="UtilityLabelTextBlock" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="UtilityHintTextBlock" Margin="0,10,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="CancelButton" Click="CancelButton_Click" Style="{StaticResource DialogSecondaryButton}" Margin="0,0,10,0"/>
                <Button x:Name="SaveButton" Click="SaveButton_Click" Style="{StaticResource DialogPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
