<Page
    x:Class="WindowsNotesApp.Pages.EditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WindowsNotesApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Modern Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsOpen="True" IsSticky="True">
            <AppBarButton Icon="Back" Label="Back" Click="Back_Click"/>
            <AppBarSeparator/>

            <AppBarButton Icon="OpenFile" Label="Open PDF" Click="OpenPdf_Click"/>
            <AppBarSeparator/>

            <AppBarToggleButton x:Name="SelectToolButton" Icon="TouchPointer" Label="Select/Pan" Click="Tool_Click" IsChecked="True"/>
            <AppBarToggleButton x:Name="PenToolButton" Icon="Edit" Label="Pen" Click="Tool_Click"/>
            <AppBarToggleButton x:Name="HighlighterToolButton" Icon="Highlight" Label="Highlighter" Click="Tool_Click"/>
            <AppBarToggleButton x:Name="EraserToolButton" Icon="Remove" Label="Eraser" Click="Tool_Click"/>
            <AppBarToggleButton x:Name="TextToolButton" Icon="Font" Label="Text" Click="Tool_Click"/>

            <AppBarSeparator/>
            <AppBarButton Icon="FormatPaint" Label="Color">
                <AppBarButton.Flyout>
                    <Flyout>
                        <ColorPicker x:Name="ToolColorPicker" ColorChanged="ToolColorPicker_ColorChanged" IsColorSpectrumVisible="True" IsColorChannelTextInputVisible="False" IsHexInputVisible="False"/>
                    </Flyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarSeparator/>

            <AppBarElementContainer>
                <ComboBox x:Name="FontSizeComboBox" SelectionChanged="FontSizeComboBox_SelectionChanged" Width="80" VerticalAlignment="Center" SelectedIndex="1">
                    <ComboBoxItem Content="12"/>
                    <ComboBoxItem Content="18"/>
                    <ComboBoxItem Content="24"/>
                    <ComboBoxItem Content="36"/>
                    <ComboBoxItem Content="48"/>
                    <ComboBoxItem Content="72"/>
                </ComboBox>
            </AppBarElementContainer>

            <AppBarSeparator/>
            <AppBarButton Icon="Save" Label="Save PDF" Click="SavePdf_Click"/>
        </CommandBar>

        <!-- PDF Viewer & Canvas -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ZoomMode="Enabled" MinZoomFactor="0.5" MaxZoomFactor="5.0">
            <StackPanel x:Name="PagesContainer" Orientation="Vertical" HorizontalAlignment="Center" Margin="20"/>
        </ScrollViewer>

        <Grid x:Name="LoadingOverlay" Grid.RowSpan="2" Background="#80000000" Visibility="Collapsed" Opacity="0" IsHitTestVisible="False">
            <Grid.Resources>
                <Storyboard x:Name="LoadingOverlayFadeIn">
                    <DoubleAnimation Storyboard.TargetName="LoadingOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" EnableDependentAnimation="True"/>
                </Storyboard>
                <Storyboard x:Name="LoadingOverlayFadeOut">
                    <DoubleAnimation Storyboard.TargetName="LoadingOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25" EnableDependentAnimation="True"/>
                </Storyboard>
            </Grid.Resources>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressRing x:Name="LoadingOverlayRing" IsActive="False" Width="48" Height="48"/>
                    <TextBlock Text="Loading Document…" FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
