<Page x:Class="Caelum.Pages.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
      Background="Transparent"
      AllowDrop="True"
      PreviewMouseDown="EditorPage_PreviewMouseDown"
      PreviewStylusDown="EditorPage_PreviewStylusDown"
      PreviewKeyDown="EditorPage_PreviewKeyDown">

    <Page.Resources>
        <!-- Toolbar button -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar toggle button -->
        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Rectangle x:Name="ActiveBar" Fill="#0078D4" Height="3" VerticalAlignment="Bottom"
                                       HorizontalAlignment="Stretch" RadiusX="1.5" RadiusY="1.5"
                                       Margin="6,0,6,2" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A0078D4"/>
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#340078D4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Selectable PDF surface. The annotation stack is image-based, so text
             selection has to come from a native PDF viewer control. -->
        <Grid x:Name="SelectablePdfContainer"
              Visibility="Collapsed"
              Margin="0,70,0,0"
              Background="#FFF6F6F6">
            <wfi:WindowsFormsHost x:Name="SelectablePdfHost" />
        </Grid>

        <!-- PDF Pages Container (full area) -->
        <ScrollViewer x:Name="PdfScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      Background="#90E5E7EB"
                      Style="{StaticResource SleekScrollViewer}"
                      PanningMode="None"
                      Stylus.IsFlicksEnabled="False"
                      IsManipulationEnabled="True"
                      PreviewStylusDown="PdfScrollViewer_PreviewStylusDown"
                      PreviewStylusMove="PdfScrollViewer_PreviewStylusMove"
                      PreviewStylusUp="PdfScrollViewer_PreviewStylusUp"
                      PreviewMouseWheel="PdfScrollViewer_PreviewMouseWheel"
                      PreviewMouseDown="PdfScrollViewer_PreviewMouseDown"
                      PreviewMouseMove="PdfScrollViewer_PreviewMouseMove"
                      PreviewMouseUp="PdfScrollViewer_PreviewMouseUp"
                      ManipulationStarting="PdfScrollViewer_ManipulationStarting"
                      ManipulationDelta="PdfScrollViewer_ManipulationDelta"
                      ManipulationInertiaStarting="PdfScrollViewer_ManipulationInertiaStarting"
                      PreviewTouchDown="PdfScrollViewer_PreviewTouchDown"
                      PreviewTouchMove="PdfScrollViewer_PreviewTouchMove"
                      PreviewTouchUp="PdfScrollViewer_PreviewTouchUp">
            <StackPanel x:Name="PagesContainer" Margin="32,20,32,32" HorizontalAlignment="Center">
                <StackPanel.LayoutTransform>
                    <ScaleTransform x:Name="PagesZoomTransform" ScaleX="1" ScaleY="1"/>
                </StackPanel.LayoutTransform>
            </StackPanel>
        </ScrollViewer>

        <!-- Floating Toolbar -->
        <Border x:Name="ToolbarBorder" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,12,0,0" Padding="8,4" CornerRadius="14"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.12" Color="#000"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" Height="42">
                <!-- Undo -->
                <Button x:Name="UndoButton" Click="UndoButton_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="42" Height="36" Margin="2,0" ToolTip="Undo (Ctrl+Z)" IsEnabled="False">
                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="#555"/>
                </Button>

                <!-- Redo -->
                <Button x:Name="RedoButton" Click="RedoButton_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="42" Height="36" Margin="2,0" ToolTip="Redo (Ctrl+Y)" IsEnabled="False">
                    <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="#555"/>
                </Button>

                <!-- Separator -->
                <Border Width="1" Background="#18000000" Margin="4,8"/>

                <!-- Pen -->
                <ToggleButton x:Name="PenToolButton" Click="PenToolButton_Click"
                        Style="{StaticResource ToolbarToggleButtonStyle}"
                        Width="42" Height="36" Margin="2,0">
                    <TextBlock x:Name="PenIcon" Text="&#xED63;" FontFamily="Segoe MDL2 Assets" FontSize="19" Foreground="#333"/>
                </ToggleButton>

                <!-- Highlighter -->
                <ToggleButton x:Name="HighlighterToolButton" Click="HighlighterToolButton_Click"
                        Style="{StaticResource ToolbarToggleButtonStyle}"
                        Width="42" Height="36" Margin="2,0" ToolTip="Freehand Highlighter">
                    <TextBlock x:Name="HighlighterIcon" Text="&#xE7E6;" FontFamily="Segoe MDL2 Assets" FontSize="19" Foreground="#F59E0B"/>
                </ToggleButton>



                <!-- Eraser -->
                <ToggleButton x:Name="EraserToolButton" Click="EraserToolButton_Click"
                        Style="{StaticResource ToolbarToggleButtonStyle}"
                        Width="42" Height="36" Margin="2,0">
                    <TextBlock x:Name="EraserIcon" Text="&#xE75C;" FontFamily="Segoe MDL2 Assets" FontSize="19" Foreground="#555"/>
                </ToggleButton>

                <!-- Select -->
                <ToggleButton x:Name="SelectToolButton" Click="SelectToolButton_Click"
                        Style="{StaticResource ToolbarToggleButtonStyle}"
                        Width="42" Height="36" Margin="2,0" ToolTip="Select and Transform">
                    <TextBlock x:Name="SelectIcon" Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#555"/>
                </ToggleButton>

                <Border Width="1" Background="#18000000" Margin="4,8"/>

                <!-- Text -->
                <ToggleButton x:Name="TextToolButton" Click="TextToolButton_Click"
                        Style="{StaticResource ToolbarToggleButtonStyle}"
                        Width="42" Height="36" Margin="2,0">
                    <TextBlock Text="A" FontSize="17" FontWeight="Bold" Foreground="#555"/>
                </ToggleButton>



                <!-- Save -->
                <Button x:Name="SavePdfButton" Click="SavePdf_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="42" Height="36" Margin="2,0" ToolTip="Save">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="#444"/>
                </Button>

                <!-- Separator -->
                <Border Width="1" Background="#18000000" Margin="4,8"/>

                <!-- Page Number -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,8,0">
                    <Grid Width="46" Height="24">
                        <TextBlock x:Name="PageNumberLabel" Text="0" FontSize="13" Foreground="#555"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"
                                   MouseLeftButtonDown="PageNumberLabel_MouseLeftButtonDown"
                                   Cursor="Hand" ToolTip="Click to jump to page"/>
                        <TextBox x:Name="PageNumberTextBox" FontSize="12" Foreground="#333" Background="#EEFFFFFF"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"
                                 Width="42" Height="22" TextAlignment="Center" Padding="2,1"
                                 BorderThickness="1" BorderBrush="#0078D4"
                                 Visibility="Collapsed"
                                 KeyDown="PageNumberTextBox_KeyDown"
                                 LostFocus="PageNumberTextBox_LostFocus"/>
                    </Grid>
                    <TextBlock x:Name="PageCountText" Text="/ 0" FontSize="13" Foreground="#555"
                               VerticalAlignment="Center" Margin="2,0,0,0"/>
                </StackPanel>

                <!-- Separator -->
                <Border Width="1" Background="#18000000" Margin="4,8"/>

                <!-- Zoom Out -->
                <Button x:Name="ZoomOutButton" Click="ZoomOutButton_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="36" Height="36" Margin="2,0" ToolTip="Zoom Out">
                    <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#555"/>
                </Button>

                <!-- Zoom Percentage (click to edit) -->
                <Grid Width="46" Height="36" Margin="0,0,0,0">
                    <TextBlock x:Name="ZoomLabel" Text="100%" FontSize="12" Foreground="#555"
                               VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"
                               MouseLeftButtonDown="ZoomLabel_MouseLeftButtonDown"
                               Cursor="Hand" ToolTip="Click to set zoom"/>
                    <TextBox x:Name="ZoomTextBox" FontSize="12" Foreground="#333" Background="#EEFFFFFF"
                             VerticalAlignment="Center" HorizontalAlignment="Center"
                             Width="42" Height="22" TextAlignment="Center" Padding="2,1"
                             BorderThickness="1" BorderBrush="#0078D4"
                             Visibility="Collapsed"
                             KeyDown="ZoomTextBox_KeyDown"
                             LostFocus="ZoomTextBox_LostFocus"/>
                </Grid>

                <!-- Zoom In -->
                <Button x:Name="ZoomInButton" Click="ZoomInButton_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="36" Height="36" Margin="2,0" ToolTip="Zoom In">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#555"/>
                </Button>


            </StackPanel>
        </Border>

        <!-- Eraser Size Preview Overlay -->
        <Ellipse x:Name="EraserSizePreviewEllipse"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Stroke="#0078D4" StrokeThickness="1.5" Fill="#150078D4"
                 IsHitTestVisible="False" Visibility="Collapsed"
                 Panel.ZIndex="10"/>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Background="#60000000" Visibility="Collapsed">
            <Border CornerRadius="14" Padding="28,20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="White" Opacity="0.92"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.10" Color="#000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="LoadingRing" Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#0078D4" RenderTransformOrigin="0.5,0.5" Margin="0,0,12,0">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Visibility, ElementName=LoadingOverlay}" Value="Visible">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="LoadingStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock x:Name="LoadingText" Text="Loading..." FontSize="15" VerticalAlignment="Center" Foreground="#444"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>


