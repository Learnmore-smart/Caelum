<Page x:Class="WindowsNotesApp.Pages.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#25000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15000000"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#200078D4"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#300078D4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#200078D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#300078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="#CCFFFFFF"
                BorderBrush="#30E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="8,4,8,4"
                CornerRadius="0,0,8,8">
            <Grid Height="40">
                <!-- Back button -->
                <Button x:Name="BackButton" Click="Back_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Left">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#333333"/>
                </Button>

                <!-- Tool buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ToggleButton x:Name="PenToolButton" Click="PenToolButton_Click"
                                  Style="{StaticResource ToolbarToggleButtonStyle}"
                                  Width="44" Height="36" Margin="2,0">
                        <TextBlock x:Name="PenIcon" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#333333"/>
                    </ToggleButton>
                    <Border x:Name="PenActiveIndicator" Width="3" Height="3" Background="#0078D4" CornerRadius="1.5" Visibility="Collapsed" Margin="0,-28,0,0"/>

                    <ToggleButton x:Name="HighlighterToolButton" Click="HighlighterToolButton_Click"
                                  Style="{StaticResource ToolbarToggleButtonStyle}"
                                  Width="44" Height="36" Margin="2,0">
                        <TextBlock x:Name="HighlighterIcon" Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FFD700"/>
                    </ToggleButton>
                    <Border x:Name="HighlighterActiveIndicator" Width="3" Height="3" Background="#0078D4" CornerRadius="1.5" Visibility="Collapsed" Margin="0,-28,0,0"/>

                    <ToggleButton x:Name="EraserToolButton" Click="EraserToolButton_Click"
                                  Style="{StaticResource ToolbarToggleButtonStyle}"
                                  Width="44" Height="36" Margin="2,0">
                        <TextBlock x:Name="EraserIcon" Text="&#xE75C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#333333"/>
                    </ToggleButton>
                    <Border x:Name="EraserActiveIndicator" Width="3" Height="3" Background="#0078D4" CornerRadius="1.5" Visibility="Collapsed" Margin="0,-28,0,0"/>

                    <ToggleButton x:Name="TextToolButton" Click="TextToolButton_Click"
                                  Style="{StaticResource ToolbarToggleButtonStyle}"
                                  Width="44" Height="36" Margin="2,0">
                        <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#333333"/>
                    </ToggleButton>
                    <Border x:Name="TextActiveIndicator" Width="3" Height="3" Background="#0078D4" CornerRadius="1.5" Visibility="Collapsed" Margin="0,-28,0,0"/>
                </StackPanel>

                <!-- Save button -->
                <Button x:Name="SavePdfButton" Click="SavePdf_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Right">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#333333"/>
                </Button>
            </Grid>
        </Border>

        <!-- PDF Pages Container -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Background="#F8F8F8">
            <StackPanel x:Name="PagesContainer" Margin="24,16,24,24"/>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="2"
              Background="#80000000" Visibility="Collapsed">
            <Border Background="#E0FFFFFF" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="LoadingRing" Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#0078D4" RenderTransformOrigin="0.5,0.5" Margin="0,0,12,0">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Visibility, ElementName=LoadingOverlay}" Value="Visible">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="LoadingStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock x:Name="LoadingText" Text="Loading Document..." FontSize="16" VerticalAlignment="Center" Foreground="#333333"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
