<Page x:Class="WindowsNotesApp.Pages.EditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <!-- Toolbar button -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#14000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar toggle button -->
        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#14000000"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#220078D4"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#340078D4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar - frosted glass -->
        <Border Grid.Row="0" Padding="8,6" CornerRadius="0,0,12,12">
            <Border.Background>
                <SolidColorBrush Color="White" Opacity="0.78"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#000"/>
            </Border.Effect>
            <Grid Height="42">
                <!-- Back button -->
                <Button x:Name="BackButton" Click="Back_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Left">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#444"/>
                </Button>

                <!-- Centered tool buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Undo -->
                    <Button x:Name="UndoButton" Click="UndoButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="44" Height="38" Margin="3,0" ToolTip="Undo (Ctrl+Z)" IsEnabled="False">
                        <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#555"/>
                    </Button>

                    <!-- Redo -->
                    <Button x:Name="RedoButton" Click="RedoButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="44" Height="38" Margin="3,0,6,0" ToolTip="Redo (Ctrl+Y)" IsEnabled="False">
                        <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#555"/>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Background="#18000000" Margin="0,8,6,8"/>

                    <!-- Pen -->
                    <Button x:Name="PenToolButton" Click="PenToolButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="44" Height="38" Margin="3,0">
                        <TextBlock x:Name="PenIcon" Text="&#xED63;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#333"/>
                    </Button>

                    <!-- Highlighter (uses Segoe MDL2 marker icon) -->
                    <Button x:Name="HighlighterToolButton" Click="HighlighterToolButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="44" Height="38" Margin="3,0">
                        <TextBlock x:Name="HighlighterIcon" Text="&#xE7E6;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#F59E0B"/>
                    </Button>

                    <!-- Eraser -->
                    <Button x:Name="EraserToolButton" Click="EraserToolButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="44" Height="38" Margin="3,0">
                        <TextBlock x:Name="EraserIcon" Text="&#xE75C;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#555"/>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Background="#18000000" Margin="6,8"/>

                    <!-- Text -->
                    <Button x:Name="TextToolButton" Click="TextToolButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="44" Height="38" Margin="3,0">
                        <TextBlock Text="A" FontSize="18" FontWeight="Bold" Foreground="#555"/>
                    </Button>
                </StackPanel>

                <!-- Save button -->
                <Button x:Name="SavePdfButton" Click="SavePdf_Click"
                        Style="{StaticResource ToolbarButtonStyle}"
                        HorizontalAlignment="Right">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#444"/>
                </Button>
            </Grid>
        </Border>

        <!-- PDF Pages Container -->
        <ScrollViewer x:Name="PdfScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      Background="#EAEAEA"
                      Style="{StaticResource SleekScrollViewer}"
                      PanningMode="Both"
                      Stylus.IsFlicksEnabled="False"
                      PreviewStylusDown="PdfScrollViewer_PreviewStylusDown"
                      PreviewStylusMove="PdfScrollViewer_PreviewStylusMove"
                      PreviewStylusUp="PdfScrollViewer_PreviewStylusUp"
                      PreviewMouseWheel="PdfScrollViewer_PreviewMouseWheel">
            <StackPanel x:Name="PagesContainer" Margin="32,20,32,32">
                <StackPanel.LayoutTransform>
                    <ScaleTransform x:Name="PagesZoomTransform" ScaleX="1" ScaleY="1"/>
                </StackPanel.LayoutTransform>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="2"
              Background="#60000000" Visibility="Collapsed">
            <Border CornerRadius="14" Padding="28,20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="White" Opacity="0.92"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.10" Color="#000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="LoadingRing" Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#0078D4" RenderTransformOrigin="0.5,0.5" Margin="0,0,12,0">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Visibility, ElementName=LoadingOverlay}" Value="Visible">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="LoadingStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock x:Name="LoadingText" Text="加载中…" FontSize="15" VerticalAlignment="Center" Foreground="#444"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
