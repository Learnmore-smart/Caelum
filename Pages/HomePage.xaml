<Page x:Class="WindowsNotesApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:WindowsNotesApp.Pages"
      Background="Transparent"
      AllowDrop="True">

    <Page.Resources>
        <!-- Invisible button style for clean tile clicks -->
        <Style x:Key="InvisibleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Add Tile: dashed border with + icon -->
        <DataTemplate x:Key="AddTileTemplate">
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="AddTile_Click" VerticalAlignment="Top">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="AddTileContainer" Width="160" Background="Transparent" Margin="20,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid x:Name="AddTileGrid" Grid.Row="0" Width="120" Height="160" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center">
                                <Grid.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Viewbox Stretch="Uniform" MaxWidth="90" MaxHeight="120" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Grid Width="90" Height="120">
                                        <Rectangle x:Name="BgRect" Fill="Transparent" RadiusX="5" RadiusY="5"/>
                                        <Rectangle Stroke="#1DA1F2" StrokeThickness="2" StrokeDashArray="6,4" RadiusX="5" RadiusY="5"/>
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="40" Foreground="#1DA1F2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- File Tile: notebook icon + info -->
        <DataTemplate x:Key="FileTileTemplate">
            <Border x:Name="FileTileBorder" Margin="20,12" Background="Transparent" CornerRadius="10" Padding="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            <Grid Width="160" Background="Transparent" Tag="{Binding}" MouseRightButtonUp="FileTile_RightClick">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Notebook icon (clickable) -->
                <Button Grid.Row="0" Style="{StaticResource InvisibleButtonStyle}"
                        Tag="{Binding}" Click="FileTile_Click" HorizontalAlignment="Center">
                    <Grid x:Name="IconGrid" Width="120" Height="160" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Viewbox Stretch="Uniform" MaxWidth="90" MaxHeight="120" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="90" Height="120">
                                <Rectangle Fill="#B88E75" RadiusX="5" RadiusY="5"/>
                                <Rectangle Fill="#D94848" Width="12" HorizontalAlignment="Left" RadiusX="5" RadiusY="5"/>
                                <Rectangle Fill="#D94848" Width="6" HorizontalAlignment="Left" Margin="6,0,0,0"/>
                                <Rectangle Fill="#A82824" Width="2" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                                <Border Background="#F5F5F5" CornerRadius="4" BorderBrush="#A08060" BorderThickness="1" Width="44" Height="22" Margin="24,16,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Rectangle Fill="#B0B0B0" Height="4" Width="24" RadiusX="2" RadiusY="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Viewbox>
                    </Grid>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Filename (no caret) -->
                <TextBlock Grid.Row="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" MaxWidth="150"
                           FontSize="13" Foreground="#333333" HorizontalAlignment="Center" Margin="0,8,0,0"
                           ToolTip="{Binding Path}"/>

                <!-- Page count + date -->
                <TextBlock Grid.Row="2" Text="{Binding InfoText}" FontSize="12" Foreground="#999999"
                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
            </Grid>
            </Border>
        </DataTemplate>

        <local:HomeTileTemplateSelector x:Key="HomeTileTemplateSelector"
                                        AddTileTemplate="{StaticResource AddTileTemplate}"
                                        FileTileTemplate="{StaticResource FileTileTemplate}"/>
    </Page.Resources>

    <Grid>
        <ScrollViewer x:Name="HomeScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource SleekScrollViewer}"
                      PreviewMouseWheel="HomeScrollViewer_PreviewMouseWheel">
            <!-- Glass card -->
            <Border CornerRadius="16" Margin="24,20,24,24"
                    BorderThickness="1"
                    BorderBrush="#15FFFFFF">
                <Border.Background>
                    <SolidColorBrush Color="Transparent"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.03" Color="#000"/>
                </Border.Effect>
                <ItemsControl x:Name="TilesGrid"
                              ItemsSource="{Binding HomeTiles}"
                              ItemTemplateSelector="{StaticResource HomeTileTemplateSelector}"
                              Margin="12,8,12,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
