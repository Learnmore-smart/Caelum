<Page
    x:Class="WindowsNotesApp.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsNotesApp.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DataType="local:HomePage"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <DataTemplate x:Key="AddTileTemplate" x:DataType="local:HomeTile">
            <Grid Width="180" Height="252" AutomationProperties.Name="Add PDF">
                <Border
                    CornerRadius="16"
                    Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Opacity="0.20"
                    Margin="0,6,0,0" />
                <Border
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="16"
                    Margin="0,0,0,6">
                    <Grid RowDefinitions="*,Auto" RowSpacing="12">
                        <Border
                            CornerRadius="12"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                            <Viewbox Stretch="Uniform" MaxWidth="64" MaxHeight="64">
                                <SymbolIcon Symbol="Add" />
                            </Viewbox>
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Text="Add PDF"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            TextAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FileTileTemplate" x:DataType="local:HomeTile">
            <Grid
                Width="180"
                Height="252"
                AutomationProperties.Name="{x:Bind FileName}"
                AutomationProperties.HelpText="{x:Bind Path}">
                <Border
                    CornerRadius="16"
                    Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Opacity="0.20"
                    Margin="0,6,0,0" />
                <Border
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="16"
                    Margin="0,0,0,6">
                    <Grid RowDefinitions="*,Auto" RowSpacing="12">
                        <Border
                            CornerRadius="12"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                            <Viewbox Stretch="Uniform" MaxWidth="56" MaxHeight="56">
                                <SymbolIcon Symbol="Document" />
                            </Viewbox>
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Text="{x:Bind FileName}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"
                            ToolTipService.ToolTip="{x:Bind Path}" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <local:HomeTileTemplateSelector
            x:Key="HomeTileTemplateSelector"
            AddTileTemplate="{StaticResource AddTileTemplate}"
            FileTileTemplate="{StaticResource FileTileTemplate}" />
    </Page.Resources>

    <Grid x:Name="LayoutRoot" Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Spacing="4">
            <TextBlock
                Text="Library"
                Style="{StaticResource TitleTextBlockStyle}"
                AutomationProperties.HeadingLevel="Level1" />
            <TextBlock Text="Recent PDFs" Opacity="0.75" />
        </StackPanel>

        <Grid Grid.Row="1">
            <GridView
                x:Name="TilesGrid"
                ItemsSource="{x:Bind HomeTiles, Mode=OneWay}"
                ItemTemplateSelector="{StaticResource HomeTileTemplateSelector}"
                IsItemClickEnabled="True"
                ItemClick="TilesGrid_ItemClick"
                AutomationProperties.Name="Recent PDFs"
                SelectionMode="None">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="196" ItemHeight="268" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="8" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="UseSystemFocusVisuals" Value="True" />
                    </Style>
                </GridView.ItemContainerStyle>
            </GridView>
        </Grid>
    </Grid>
</Page>
