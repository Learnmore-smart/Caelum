<Page x:Class="Caelum.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Caelum.Pages"
      Background="Transparent"
      AllowDrop="True">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="InvisibleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectionActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogSecondaryButton}">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectionDangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#B91C1C"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FECACA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AddTileTemplate">
                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="AddTile_Click" VerticalAlignment="Top">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsSelectionMode, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="AddTileContainer" Width="160" Background="Transparent" Margin="20,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid x:Name="AddTileGrid" Grid.Row="0" Width="120" Height="160" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center">
                                <Grid.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Viewbox Stretch="Uniform" MaxWidth="90" MaxHeight="120" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Grid Width="90" Height="120">
                                        <Rectangle x:Name="BgRect" Fill="Transparent" RadiusX="5" RadiusY="5"/>
                                        <Rectangle Stroke="#1DA1F2" StrokeThickness="2" StrokeDashArray="6,4" RadiusX="5" RadiusY="5"/>
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="40" Foreground="#1DA1F2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AddTileGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="FileTileTemplate">
            <Border x:Name="FileTileBorder" Margin="20,12" Background="Transparent" CornerRadius="10" Padding="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#120078D4"/>
                                <Setter Property="BorderBrush" Value="#400078D4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Width="160" Background="Transparent" Tag="{Binding}" MouseRightButtonUp="FileTile_RightClick">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Width="24"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,8,10,0"
                            CornerRadius="12"
                            BorderThickness="1"
                            IsHitTestVisible="False"
                            Visibility="{Binding DataContext.IsSelectionMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="#2563EB"/>
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Button Grid.Row="0" Style="{StaticResource InvisibleButtonStyle}"
                            Tag="{Binding}" Click="FileTile_Click" HorizontalAlignment="Center">
                        <Grid x:Name="IconGrid" Width="120" Height="160" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Viewbox Stretch="Uniform" MaxWidth="90" MaxHeight="120" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid Width="90" Height="120">
                                    <Rectangle Fill="#B88E75" RadiusX="5" RadiusY="5"/>
                                    <Rectangle Fill="#D94848" Width="12" HorizontalAlignment="Left" RadiusX="5" RadiusY="5"/>
                                    <Rectangle Fill="#D94848" Width="6" HorizontalAlignment="Left" Margin="6,0,0,0"/>
                                    <Rectangle Fill="#A82824" Width="2" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                                    <Border Background="#F5F5F5" CornerRadius="4" BorderBrush="#A08060" BorderThickness="1" Width="44" Height="22" Margin="24,16,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                        <Rectangle Fill="#B0B0B0" Height="4" Width="24" RadiusX="2" RadiusY="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Viewbox>
                        </Grid>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="IconGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>

                    <TextBlock Grid.Row="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" MaxWidth="150"
                               FontSize="13" Foreground="#333333" HorizontalAlignment="Center" Margin="0,8,0,0"
                               ToolTip="{Binding Path}"/>

                    <TextBlock Grid.Row="2" Text="{Binding InfoText}" FontSize="12" Foreground="#999999"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <local:HomeTileTemplateSelector x:Key="HomeTileTemplateSelector"
                                        AddTileTemplate="{StaticResource AddTileTemplate}"
                                        FileTileTemplate="{StaticResource FileTileTemplate}"/>
    </Page.Resources>

    <Grid>
        <ScrollViewer x:Name="HomeScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource SleekScrollViewer}"
                      PreviewMouseWheel="HomeScrollViewer_PreviewMouseWheel">
            <StackPanel>
                <StackPanel Margin="24,24,24,6">
                    <TextBlock x:Name="HomeTitleTextBlock" FontSize="28" FontWeight="SemiBold" Foreground="#1F2937"/>
                    <TextBlock x:Name="HomeSubtitleTextBlock" Margin="0,8,0,0" FontSize="13" Foreground="#6B7280" TextWrapping="Wrap"/>
                </StackPanel>
                <ItemsControl x:Name="TilesGrid"
                              ItemsSource="{Binding HomeTiles}"
                              ItemTemplateSelector="{StaticResource HomeTileTemplateSelector}"
                              Margin="12,4,12,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
